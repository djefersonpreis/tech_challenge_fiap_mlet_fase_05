# Ignorar ambientes virtuais
venv/
env/
ENV/
.venv/

# Ignorar cache Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Ignorar notebooks checkpoints
.ipynb_checkpoints/

# Ignorar modelos treinados (podem ser grandes)
models/*.keras
models/*.h5
models/*.pkl

# Ignorar dados (podem ser grandes)
data/*.csv
data/*.parquet

# Ignorar gráficos gerados
*.png
*.jpg
*.jpeg

# Ignorar logs
*.log

# Ignorar IDE
.vscode/
.idea/
*.swp
*.swo

# Ignorar OS
.DS_Store
Thumbs.db

# Ignorar testes
.pytest_cache/
.coverage
htmlcov/

# Ignorar Docker
.dockerignore
